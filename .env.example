# ============================================================
#  Synapse — Environment Variables
#  Copy to .env.local (dev) or .env.production (deploy)
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/synapse

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate: openssl rand -base64 32

# ── Admin Panel ──────────────────────────────────────────────
ADMIN_EMAIL=admin@synapse.app
ADMIN_PASSWORD=

# ── Public URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ── Socket Server ────────────────────────────────────────────
SOCKET_PORT=3001

# ── TURN/STUN (WebRTC) ──────────────────────────────────────
NEXT_PUBLIC_TURN_URL=          # e.g. turn:your-server.com:3478
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# ── Payments: USDT TRC-20 ───────────────────────────────────
USDT_WALLET_ADDRESS=           # Your TRC-20 USDT wallet
TRONGRID_API_URL=https://api.trongrid.io
TRONGRID_API_KEY=              # Optional — increases rate limits

# ── Payments: LemonSqueezy ───────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_PLUS_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PLUS_YEARLY_VARIANT_ID=
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=

# ── Cron Jobs ────────────────────────────────────────────────
CRON_SECRET=                   # Generate: openssl rand -hex 16

# ── Sentry (Error Monitoring) ────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── Content Moderation (Video) ───────────────────────────────
MODERATION_PROVIDER=           # "sightengine" | "google" | ""
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
GOOGLE_VISION_API_KEY=

# ── Text Moderation (AI) ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=               # Optional: custom endpoint

# ── Push Notifications ──────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # Generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
